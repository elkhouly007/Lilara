{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lilara.config.schema.json",
  "title": "Agent Runtime Guard project config",
  "description": "Schema for lilara.config.json. Validated by runtime/config-validator.js.",
  "type": "object",
  "properties": {
    "_comment":  { "type": "string" },
    "profile":   { "type": "string", "enum": ["minimal", "rules", "agents", "skills", "full"] },
    "languages": { "type": "array",  "items": { "type": "string" } },
    "agents":    { "type": "array",  "items": { "type": "string" } },
    "skills":    { "type": "array",  "items": { "type": "string" } },
    "extra_rules": { "type": "array", "items": { "type": "string" } },
    "runtime": {
      "type": "object",
      "properties": {
        "trust_posture": {
          "type": "string",
          "enum": ["relaxed", "balanced", "strict"]
        },
        "protected_branches": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sensitive_path_patterns": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "properties": {
        "required_steps": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Steps that must be marked complete before commit. E.g. [\"test\", \"review\", \"commit\"]."
        },
        "step_order": {
          "type": "string",
          "enum": ["strict", "lenient"],
          "description": "strict = steps must complete in declared order; lenient = any order before commit."
        },
        "_comment": { "type": "string" }
      },
      "additionalProperties": false
    },
    "taint": {
      "type": "object",
      "description": "Controls taint-tracking behaviour for secret/sensitive token detection.",
      "properties": {
        "minTokenLength": {
          "type": "number",
          "minimum": 4,
          "maximum": 32,
          "description": "Minimum token length considered for taint analysis (4–32)."
        },
        "safeToolClasses": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tool classes whose outputs are not treated as taint sources."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
