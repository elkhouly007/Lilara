{
  "_comment": "Lilara per-project config. Copy to lilara.config.json in your project root and customize. Run scripts/install-local.sh to apply.",

  "profile": "rules",

  "languages": ["typescript", "python", "database"],

  "agents": [
    "code-reviewer",
    "security-reviewer",
    "typescript-reviewer",
    "python-reviewer",
    "database-reviewer",
    "tdd-guide",
    "architect",
    "planner"
  ],

  "skills": [
    "code-review",
    "security-review",
    "tdd",
    "plan-feature",
    "git-review"
  ],

  "extra_rules": [],

  "runtime": {
    "trust_posture": "balanced",
    "protected_branches": ["main", "master"],
    "sensitive_path_patterns": ["prod", "production", "secrets", "credentials", ".env", "terraform", "infra"]
  },

  "workflow": {
    "required_steps": ["test", "review", "commit"],
    "step_order": "strict",
    "_comment": "Strict = steps must complete in declared order before commit; lenient = any order before commit. Remove this block to disable workflow enforcement."
  }
}
