# Lilara inviolable-tier lattice integrity baseline — ADR-036.
#
# Line format:  <key> <sha256:HEX>
#
# lattice    — sha256 of computeLatticeHash() projection:
#              { version, floors:[{id,rung,action,demotableBy(sorted),tier},...] }
#              via runtime/decision-lattice.js:computeLatticeHash()
#
# floor-codes — raw sha256 of runtime/floor-codes.js (the typed-code registry;
#               an attacker widening a demotableBy[] must also edit floor-codes
#               to add new aliases, so we cover both files).
#
# Verify:  bash scripts/check-inviolable-tier.sh
# Update:  bash scripts/check-inviolable-tier.sh --update
# (Commit the updated file after any intentional lattice or floor-codes change.)
lattice sha256:a042c81004cd4332ceb89a92fea886ba6d1e017ff466406e42525b2e9b4adc39
floor-codes sha256:ac4e58aa435581047dea88454628e87b3f6eaa6e86473cc1d0937a96c1e3d031
