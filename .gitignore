# ── Runtime ephemeral output ─────────────────────────────────────────────────
ann*.json
jobs*.json
ubuntu_log.txt

# ── Benchmark artifacts ───────────────────────────────────────────────────────
artifacts/adversarial/
artifacts/bench/
artifacts/perf/
artifacts/stress/

# ── Claude Code session artifacts ─────────────────────────────────────────────
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/

# ── Corrupt-state backups ──────────────────────────────────────────────────────
*.corrupt-*.bak

# ── Self-install snapshot (generated by scripts/install.sh) ───────────────────
# Should never be tracked in the repo. ~/.horus/ user-state lives outside the repo;
# this entry guards against a stray `bash scripts/install.sh .` polluting the tree.
.horus/

# ── Overnight run reports ─────────────────────────────────────────────────────
OVERNIGHT_*.md
OVERNIGHT_QUEUE_*.md

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
*.swp
