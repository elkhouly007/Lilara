# ── Runtime ephemeral output ─────────────────────────────────────────────────
ann*.json
jobs*.json
ubuntu_log.txt

# ── Benchmark artifacts ───────────────────────────────────────────────────────
# ADR-044: baseline.json files are committed (no CI cache dependency).
# All other bench/perf output remains untracked.
artifacts/adversarial/
artifacts/bench/*
!artifacts/bench/baseline.json
artifacts/perf/*
!artifacts/perf/baseline.json
artifacts/stress/

# ── Claude Code session artifacts ─────────────────────────────────────────────
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/

# ── Git worktrees ─────────────────────────────────────────────────────────────
.worktrees/

# ── Corrupt-state backups ──────────────────────────────────────────────────────
*.corrupt-*.bak

# ── Self-install snapshot (generated by scripts/install.sh) ───────────────────
# Should never be tracked in the repo. ~/.horus/ user-state lives outside the repo;
# this entry guards against a stray `bash scripts/install.sh .` polluting the tree.
.horus/

# ── Overnight run reports ─────────────────────────────────────────────────────
OVERNIGHT_*.md
OVERNIGHT_QUEUE_*.md

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
# Zero-dep project — npm auto-generates this even when there are no deps;
# never commit it.
package-lock.json

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
*.swp

decision-journal.jsonl
